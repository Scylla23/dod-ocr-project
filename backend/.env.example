# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as documentation.

# Provider selection — which provider is the default if the user
# doesn't pick one in the frontend dropdown.
# Options: anthropic | openai
EXTRACTOR_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: override the Claude model. Defaults to claude-sonnet-4-5.
# Other options: claude-haiku-4-5-20251001, claude-opus-4-7
# ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OpenAI / OpenAI-compatible ---
# Used by the "openai" provider. Works with OpenAI directly, or with any
# OpenAI-compatible endpoint (Ollama, vLLM, Together, OpenRouter, etc.)
OPENAI_API_KEY=sk-your-key-here
# Optional: override base URL for non-OpenAI providers.
# OpenAI:    https://api.openai.com/v1   (default)
# Ollama:    http://localhost:11434/v1
# Together:  https://api.together.xyz/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: override the model. Defaults to gpt-4o-mini.
# OpenAI examples:  gpt-4o, gpt-4o-mini
# Ollama examples:  qwen2.5vl:7b, llava:13b
# OPENAI_MODEL=gpt-4o-mini
